{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"dialog:default",
		"fs:default",
		"fs:allow-read-text-file",
		"fs:allow-write-text-file",
		"fs:allow-rename",
		"fs:allow-remove",
		"fs:allow-watch",
		{
			"identifier": "fs:allow-rename",
			"allow": [{ "path": "$HOME/**" }]
		},
		{
			"identifier": "fs:allow-write-text-file",
			"allow": [{ "path": "$HOME/**" }]
		}
	]
}
